---
// TestimonialCarousel.astro
// Assumes you have some testimonials data, for now using dummy data

const testimonials = [
  {
    name: "Sarah M.",
    location: "North Vancouver",
    quote: "ABC Electrical rewired our entire 1960s home. On time, on budget, and they cleaned up perfectly. Highly recommend!",
    rating: 5,
    image: "https://randomuser.me/api/portraits/women/68.jpg"
  },
  {
    name: "John D.",
    location: "Downtown Vancouver",
    quote: "Exceptional service! They installed our EV charger efficiently and professionally. The team was courteous and knowledgeable.",
    rating: 5,
    image: "https://randomuser.me/api/portraits/men/32.jpg"
  },
  {
    name: "Emily R.",
    location: "Burnaby",
    quote: "Had a sudden power outage, and ABC Electrical was there within the hour. Fixed the issue quickly. Lifesavers!",
    rating: 5,
    image: "https://randomuser.me/api/portraits/women/44.jpg"
  },
  {
    name: "Michael B.",
    location: "Richmond",
    quote: "Great experience updating our commercial lighting. Increased efficiency and looks fantastic. Highly recommend for businesses.",
    rating: 4.5,
    image: "https://randomuser.me/api/portraits/men/82.jpg"
  },
];

function getStars(rating) {
  let stars = [];
  for (let i = 0; i < Math.floor(rating); i++) {
    stars.push(`<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gold" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.539 1.118l-2.8-2.034a1 1 0 00-1.176 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.381-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>`);
  }
  if (rating % 1 !== 0) {
    stars.push(`<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gold" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.539 1.118l-2.8-2.034a1 1 0 00-1.176 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.381-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1h2a1 1 0 110 2h-2v2a1 1 0 11-2 0V6H7a1 1 0 110-2h2V3a1 1 0 011-1z" clip-rule="evenodd" opacity=".5" /></svg>`); // Half star representation if needed
  }
  return stars.join('');
}
---

<div class="relative">
  <div class="carousel-container overflow-hidden w-full">
    <div class="carousel-track flex transition-transform duration-500 ease-in-out" id="testimonials-track">
      {testimonials.map((testimonial) => (
        <div class="carousel-slide flex-shrink-0 w-full md:w-1/2 lg:w-1/3 p-4">
          <div class="bg-white rounded-lg p-8 shadow-xl flex flex-col items-center text-center h-full" data-aos="fade-up">
            <img src={testimonial.image} alt={testimonial.name} class="w-20 h-20 rounded-full mb-4 object-cover border-4 border-gold"/>
            <div class="flex mb-3" set:html={getStars(testimonial.rating)}></div>
            <p class="text-lg text-slate mb-4 italic leading-relaxed">"{testimonial.quote}"</p>
            <p class="font-sans text-gold font-semibold">— {testimonial.name}, <span class="text-teal">{testimonial.location}</span></p>
          </div>
        </div>
      ))}
    </div>
  </div>
  
  <button id="prev-btn" class="absolute left-0 top-1/2 -translate-y-1/2 bg-charcoal/50 hover:bg-charcoal/70 text-white p-3 rounded-full shadow-lg z-20 transition-colors hidden md:block">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
  </button>
  <button id="next-btn" class="absolute right-0 top-1/2 -translate-y-1/2 bg-charcoal/50 hover:bg-charcoal/70 text-white p-3 rounded-full shadow-lg z-20 transition-colors hidden md:block">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
  </button>

  <div class="carousel-dots flex justify-center mt-8 space-x-2">
    {testimonials.map((_, index) => (
      <button class="dot w-3 h-3 rounded-full bg-stone-400 hover:bg-gold transition-colors" data-slide={index}></button>
    ))}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('testimonials-track');
    const slides = Array.from(track.children);
    const nextButton = document.getElementById('next-btn');
    const prevButton = document.getElementById('prev-btn');
    const dotsContainer = document.querySelector('.carousel-dots');
    const dots = Array.from(dotsContainer.children);

    let slideWidth;
    let currentSlide = 0;
    let slidesPerPage;

    const setSlideDimensions = () => {
      if (window.innerWidth >= 1024) { // lg breakpoint
        slidesPerPage = 3;
      } else if (window.innerWidth >= 768) { // md breakpoint
        slidesPerPage = 2;
      } else {
        slidesPerPage = 1;
      }
      slideWidth = track.clientWidth / slidesPerPage;
      slides.forEach(slide => (slide.style.width = `${slideWidth}px`));
      moveToSlide(currentSlide);
    };

    const moveToSlide = (slideIndex) => {
      track.style.transform = `translateX(${-slideWidth * slideIndex}px)`;
      updateDots(slideIndex);
      currentSlide = slideIndex;
    };

    const updateDots = (slideIndex) => {
        dots.forEach(dot => dot.classList.remove('bg-gold', 'scale-125'));
        dots[slideIndex].classList.add('bg-gold', 'scale-125');
    }

    nextButton.addEventListener('click', () => {
      const totalSlides = slides.length;
      let nextSlide = currentSlide + 1;
      if (nextSlide > totalSlides - slidesPerPage) {
          nextSlide = 0; // Loop back to the start
      }
      moveToSlide(nextSlide);
    });

    prevButton.addEventListener('click', () => {
      const totalSlides = slides.length;
      let prevSlide = currentSlide - 1;
      if (prevSlide < 0) {
          prevSlide = totalSlides - slidesPerPage; // Loop to the end
      }
      moveToSlide(prevSlide);
    });

    dots.forEach(dot => {
      dot.addEventListener('click', (e) => {
        const slideToMove = parseInt(e.target.dataset.slide);
        moveToSlide(slideToMove);
      });
    });

    // Initial setup and resize listener
    setSlideDimensions();
    window.addEventListener('resize', setSlideDimensions);

    // Autoplay (optional)
    let autoplayInterval = setInterval(() => {
        const totalSlides = slides.length;
        let nextSlide = currentSlide + 1;
        if (nextSlide > totalSlides - slidesPerPage) {
            nextSlide = 0; 
        }
        moveToSlide(nextSlide);
    }, 5000); // Change slide every 5 seconds

    // Pause autoplay on hover
    const carouselContainer = document.querySelector('.carousel-container');
    carouselContainer.addEventListener('mouseenter', () => clearInterval(autoplayInterval));
    carouselContainer.addEventListener('mouseleave', () => {
        autoplayInterval = setInterval(() => {
            const totalSlides = slides.length;
            let nextSlide = currentSlide + 1;
            if (nextSlide > totalSlides - slidesPerPage) {
                nextSlide = 0; 
            }
            moveToSlide(nextSlide);
        }, 5000);
    });
  });
</script>