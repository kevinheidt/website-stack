---
import MainLayout from '../layouts/main.astro';

const projects = [
  {
    title: 'Complete Home Rewire',
    description: '1960s bungalow in Burnaby. Full panel upgrade + rewiring. Before & after.',
    image: 'https://placehold.co/600x400/1e3a5f/f5a623?text=Home+Rewire',
    category: 'Residential',
  },
  {
    title: 'EV Charger Install',
    description: 'Tesla Wall Connector installation, Vancouver home.',
    image: 'https://placehold.co/600x400/f5a623/1e3a5f?text=EV+Charger',
    category: 'Residential',
  },
  {
    title: 'Retail Buildout',
    description: 'New lighting & electrical for a Gastown retail space.',
    image: 'https://placehold.co/600x400/1e3a5f/f5a623?text=Retail+Buildout',
    category: 'Commercial',
  },
  {
    title: 'Smart Home Upgrade',
    description: 'Integrated lighting, security wiring, and automation for a West Vancouver home.',
    image: 'https://placehold.co/600x400/f5a623/1e3a5f?text=Smart+Home',
    category: 'Residential',
  },
  {
    title: 'Commercial Office',
    description: 'Full electrical for a 5,000 sq ft office space in Surrey.',
    image: 'https://placehold.co/600x400/1e3a5f/f5a623?text=Commercial+Office',
    category: 'Commercial',
  },
  {
    title: 'Outdoor Lighting',
    description: 'Landscape and security lighting for a South Surrey property.',
    image: 'https://placehold.co/600x400/f5a623/1e3a5f?text=Outdoor+Lighting',
    category: 'Residential',
  },
];
---

<MainLayout 
  title="Our Work | ABC Electrical"
  description="See our completed electrical projects. From home rewires to commercial buildouts, view our portfolio of work across Vancouver and the Lower Mainland."
>
  <!-- Hero Section -->
  <section class="relative bg-[#1e3a5f] py-24 md:py-32">
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <defs>
          <pattern id="gallery-grid" width="10" height="10" patternUnits="userSpaceOnUse">
            <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100" height="100" fill="url(#gallery-grid)" />
      </svg>
    </div>
    
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Our Work</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Quality electrical work you can see. Browse our recent projects.
      </p>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="py-16 md:py-24 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <div class="card-hover bg-white rounded-xl overflow-hidden shadow-md border border-gray-100">
            <div class="relative">
              <img 
                src={project.image} 
                alt={project.title} 
                class="w-full h-64 object-cover"
                loading="lazy"
              />
              <div class="absolute top-4 left-4">
                <span class="bg-[#f5a623] text-[#1e3a5f] px-3 py-1 rounded-full text-sm font-semibold">
                  {project.category}
                </span>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-[#1e3a5f] mb-2">{project.title}</h3>
              <p class="text-gray-600">{project.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-4xl md:text-5xl font-bold text-[#1e3a5f] mb-2">500+</p>
          <p class="text-gray-600">Projects Completed</p>
        </div>
        <div>
          <p class="text-4xl md:text-5xl font-bold text-[#1e3a5f] mb-2">12+</p>
          <p class="text-gray-600">Years Experience</p>
        </div>
        <div>
          <p class="text-4xl md:text-5xl font-bold text-[#1e3a5f] mb-2">8</p>
          <p class="text-gray-600">Licensed Electricians</p>
        </div>
        <div>
          <p class="text-4xl md:text-5xl font-bold text-[#f5a623] mb-2">100%</p>
          <p class="text-gray-600">Satisfaction Guaranteed</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 md:py-24 bg-[#1e3a5f]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">What Our Clients Say</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-8">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-[#f5a623] mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <p class="text-gray-600 mb-4">"ABC Electrical rewired our entire 1960s home. On time, on budget, and they cleaned up perfectly. Highly recommend!"</p>
          <p class="text-[#1e3a5f] font-semibold">— Sarah M., North Vancouver</p>
        </div>
        
        <div class="bg-white rounded-xl p-8">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-[#f5a623] mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <p class="text-gray-600 mb-4">"Professional, efficient, and fairly priced. They installed our EV charger in just a few hours. Great work!"</p>
          <p class="text-[#1e3a5f] font-semibold">— James L., Vancouver</p>
        </div>
        
        <div class="bg-white rounded-xl p-8">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-[#f5a623] mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <p class="text-gray-600 mb-4">"They handled the electrical for our new retail space. Everything passed inspection on the first try. Very impressed!"</p>
          <p class="text-[#1e3a5f] font-semibold">— Michelle T., Burnaby</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 bg-[#f5a623]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-[#1e3a5f] mb-6">Ready to Start Your Project?</h2>
      <p class="text-[#1e3a5f] text-lg mb-8 max-w-2xl mx-auto">Let's add your project to our portfolio. Contact us for a free estimate.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:6045550199" class="bg-[#1e3a5f] text-white px-8 py-4 rounded-lg text-lg font-semibold shadow-lg hover:bg-[#152d4a] transition-all inline-flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (604) 555-0199
        </a>
        <a href="/contact" class="bg-white text-[#1e3a5f] px-8 py-4 rounded-lg text-lg font-semibold shadow-lg hover:bg-gray-100 transition-all inline-flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
          </svg>
          Request a Quote
        </a>
      </div>
    </div>
  </section>
</MainLayout>
