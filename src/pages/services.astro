---
import MainLayout from '../layouts/main.astro';

const residentialServices = [
  'Panel upgrades (100A → 200A)',
  'Whole-home rewiring',
  'Lighting installation (pot lights, dimmers, outdoor)',
  'EV charger installation (Tesla, Ford, all brands)',
  'Smart home wiring',
  'Ceiling fan installation',
  'Outlet & switch repairs',
  'Smoke & CO detector installation',
];

const commercialServices = [
  'New construction wiring',
  'Tenant improvements & buildouts',
  'Office & retail lighting',
  'Data & network cabling',
  'Emergency & exit lighting',
  'Electrical inspections & code compliance',
  'Panel maintenance & upgrades',
];

const emergencyServices = [
  '24/7 availability',
  'Power outage troubleshooting',
  'Electrical fire damage repair',
  'Storm damage response',
];
---

<MainLayout 
  title="Our Services | ABC Electrical"
  description="Complete electrical services for residential and commercial clients in Vancouver. Panel upgrades, rewiring, EV chargers, emergency repairs, and more. Call (604) 555-0199."
>
  <!-- Hero Section -->
  <section class="relative bg-[#1e3a5f] py-24 md:py-32">
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <defs>
          <pattern id="services-grid" width="10" height="10" patternUnits="userSpaceOnUse">
            <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100" height="100" fill="url(#services-grid)" />
      </svg>
    </div>
    
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Our Services</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        From residential repairs to commercial buildouts, we handle it all
      </p>
    </div>
  </section>

  <!-- Residential Services -->
  <section class="py-16 md:py-24 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="flex items-center mb-6">
            <div class="w-14 h-14 bg-[#1e3a5f] rounded-lg flex items-center justify-center mr-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-[#f5a623]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            </div>
            <h2 class="text-3xl md:text-4xl font-bold text-[#1e3a5f]">Residential</h2>
          </div>
          <p class="text-gray-600 text-lg mb-6">
            Your home is your sanctuary. Whether you need a simple repair or a complete electrical overhaul, we treat your home with the respect it deserves.
          </p>
          <ul class="space-y-3">
            {residentialServices.map((service) => (
              <li class="flex items-start">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#f5a623] mr-3 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">{service}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <img 
            src="https://placehold.co/600x450/1e3a5f/f5a623?text=Residential+Electrical" 
            alt="Residential electrical services" 
            class="rounded-xl shadow-lg w-full"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Commercial Services -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <img 
            src="https://placehold.co/600x450/f5a623/1e3a5f?text=Commercial+Electrical" 
            alt="Commercial electrical services" 
            class="rounded-xl shadow-lg w-full"
            loading="lazy"
          />
        </div>
        <div class="order-1 lg:order-2">
          <div class="flex items-center mb-6">
            <div class="w-14 h-14 bg-[#f5a623] rounded-lg flex items-center justify-center mr-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-[#1e3a5f]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h2 class="text-3xl md:text-4xl font-bold text-[#1e3a5f]">Commercial</h2>
          </div>
          <p class="text-gray-600 text-lg mb-6">
            Time is money in business. We work efficiently to minimize disruption to your operations while delivering code-compliant electrical solutions.
          </p>
          <ul class="space-y-3">
            {commercialServices.map((service) => (
              <li class="flex items-start">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#f5a623] mr-3 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">{service}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Emergency Services -->
  <section class="py-16 md:py-24 bg-[#1e3a5f]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="flex items-center mb-6">
            <div class="w-14 h-14 bg-[#f5a623] rounded-lg flex items-center justify-center mr-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-[#1e3a5f]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h2 class="text-3xl md:text-4xl font-bold text-white">Emergency</h2>
          </div>
          <p class="text-gray-300 text-lg mb-6">
            Electrical emergencies don't wait for business hours. That's why we're available 24/7 to handle urgent electrical issues across the Lower Mainland.
          </p>
          <ul class="space-y-3">
            {emergencyServices.map((service) => (
              <li class="flex items-start">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#f5a623] mr-3 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-300">{service}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:6045550199" class="inline-flex items-center bg-[#f5a623] text-[#1e3a5f] px-6 py-3 rounded-lg font-semibold hover:bg-[#e09420] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Call Now: (604) 555-0199
            </a>
          </div>
        </div>
        <div>
          <img 
            src="https://placehold.co/600x450/f5a623/1e3a5f?text=24%2F7+Emergency" 
            alt="24/7 Emergency electrical services" 
            class="rounded-xl shadow-lg w-full"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 md:py-24 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-[#1e3a5f] mb-4">Service Areas</h2>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto">We serve the entire Lower Mainland</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {['Vancouver', 'Burnaby', 'Richmond', 'Surrey', 'North Vancouver', 'West Vancouver', 'Coquitlam', 'New Westminster'].map((area) => (
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <span class="text-[#1e3a5f] font-semibold">{area}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 bg-[#f5a623]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-[#1e3a5f] mb-6">Need Electrical Work?</h2>
      <p class="text-[#1e3a5f] text-lg mb-8 max-w-2xl mx-auto">Get a free estimate for your project. No obligation, no pressure.</p>
      <a href="/contact" class="inline-flex items-center bg-[#1e3a5f] text-white px-8 py-4 rounded-lg text-lg font-semibold shadow-lg hover:bg-[#152d4a] transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
        Get Your Free Quote
      </a>
    </div>
  </section>
</MainLayout>
