---
import MainLayout from '../layouts/main.astro';

const serviceOptions = [
  { value: '', label: 'Select a service type' },
  { value: 'residential', label: 'Residential' },
  { value: 'commercial', label: 'Commercial' },
  { value: 'emergency', label: 'Emergency' },
  { value: 'other', label: 'Other' },
];
---

<MainLayout 
  title="Contact Us | ABC Electrical"
  description="Contact ABC Electrical for a free estimate. Call (604) 555-0199 or fill out our online form. Serving Vancouver and the Lower Mainland."
>
  <!-- Hero Section -->
  <section class="relative bg-[#1e3a5f] py-24 md:py-32">
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <defs>
          <pattern id="contact-grid" width="10" height="10" patternUnits="userSpaceOnUse">
            <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100" height="100" fill="url(#contact-grid)" />
      </svg>
    </div>
    
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Get In Touch</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Ready to start your project? We're here to help.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-3xl font-bold text-[#1e3a5f] mb-6">Contact Information</h2>
          <p class="text-gray-600 text-lg mb-8">
            Have a question or ready to get started? Reach out to us using any of the methods below. We typically respond within 2 business hours. For emergencies, call us directly.
          </p>
          
          <div class="space-y-6">
            <!-- Phone -->
            <div class="flex items-start">
              <div class="w-12 h-12 bg-[#1e3a5f] rounded-lg flex items-center justify-center flex-shrink-0 mr-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#f5a623]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-[#1e3a5f]">Phone</h3>
                <a href="tel:6045550199" class="text-gray-600 hover:text-[#f5a623] transition-colors text-lg">(604) 555-0199</a>
                <p class="text-sm text-[#f5a623] font-semibold mt-1">24/7 Emergency Service Available</p>
              </div>
            </div>
            
            <!-- Email -->
            <div class="flex items-start">
              <div class="w-12 h-12 bg-[#1e3a5f] rounded-lg flex items-center justify-center flex-shrink-0 mr-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#f5a623]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-[#1e3a5f]">Email</h3>
                <a href="mailto:hello@abcelectrical.ca" class="text-gray-600 hover:text-[#f5a623] transition-colors text-lg">hello@abcelectrical.ca</a>
              </div>
            </div>
            
            <!-- Address -->
            <div class="flex items-start">
              <div class="w-12 h-12 bg-[#1e3a5f] rounded-lg flex items-center justify-center flex-shrink-0 mr-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#f5a623]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-[#1e3a5f]">Address</h3>
                <p class="text-gray-600 text-lg">Unit 4, 1234 Main Street<br>Vancouver, BC V6B 1A1</p>
              </div>
            </div>
            
            <!-- Hours -->
            <div class="flex items-start">
              <div class="w-12 h-12 bg-[#1e3a5f] rounded-lg flex items-center justify-center flex-shrink-0 mr-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#f5a623]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-[#1e3a5f]">Hours</h3>
                <p class="text-gray-600 text-lg">Mon-Fri: 7am-5pm</p>
                <p class="text-[#f5a623] font-semibold">Emergency: 24/7</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Contact Form -->
        <div class="bg-gray-50 rounded-xl p-8 border border-gray-100">
          <h2 class="text-2xl font-bold text-[#1e3a5f] mb-6">Send Us a Message</h2>
          
          <form action="#" method="POST" class="space-y-6">
            <!-- Name -->
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-[#f5a623] focus:border-transparent transition-all"
                placeholder="Your name"
              />
            </div>
            
            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-[#f5a623] focus:border-transparent transition-all"
                placeholder="your@email.com"
              />
            </div>
            
            <!-- Phone -->
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone</label>
              <input 
                type="tel" 
                id="phone" 
                name="phone" 
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-[#f5a623] focus:border-transparent transition-all"
                placeholder="(604) 555-0123"
              />
            </div>
            
            <!-- Service Type -->
            <div>
              <label for="service-type" class="block text-sm font-medium text-gray-700 mb-2">Service Type</label>
              <select 
                id="service-type" 
                name="service-type" 
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-[#f5a623] focus:border-transparent transition-all bg-white"
              >
                {serviceOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </div>
            
            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message</label>
              <textarea 
                id="message" 
                name="message" 
                rows="4" 
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-[#f5a623] focus:border-transparent transition-all resize-none"
                placeholder="Tell us about your project..."
              ></textarea>
            </div>
            
            <!-- Submit Button -->
            <button 
              type="submit" 
              class="w-full btn-primary py-4 rounded-lg text-lg font-semibold shadow-lg"
            >
              Send Message
            </button>
          </form>
          
          <p class="text-sm text-gray-500 mt-4 text-center">
            We typically respond within 2 business hours. For emergencies, call us directly.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section (Placeholder) -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-[#1e3a5f] mb-4">Service Area</h2>
        <p class="text-gray-600 text-lg">Serving Vancouver and the entire Lower Mainland</p>
      </div>
      
      <div class="bg-gray-200 rounded-xl overflow-hidden h-96 flex items-center justify-center">
        <img 
          src="https://placehold.co/1200x500/1e3a5f/f5a623?text=Service+Area+Map+-+Vancouver+%26+Lower+Mainland" 
          alt="Service area map showing Vancouver and Lower Mainland" 
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Emergency CTA -->
  <section class="py-16 md:py-24 bg-[#f5a623]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-[#1e3a5f] mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        <h2 class="text-3xl md:text-4xl font-bold text-[#1e3a5f]">Electrical Emergency?</h2>
      </div>
      <p class="text-[#1e3a5f] text-lg mb-8 max-w-2xl mx-auto">Don't wait. Our emergency team is available 24/7 to handle urgent electrical issues.</p>
      <a href="tel:6045550199" class="inline-flex items-center bg-[#1e3a5f] text-white px-8 py-4 rounded-lg text-lg font-semibold shadow-lg hover:bg-[#152d4a] transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call Now: (604) 555-0199
      </a>
    </div>
  </section>
</MainLayout>
