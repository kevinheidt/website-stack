---
import MainLayout from '../layouts/main.astro';
---

<MainLayout 
  title="About Us | ABC Electrical"
  description="Learn about ABC Electrical. Founded in 2012 by master electrician Dave Chen, we're a team of 8 licensed electricians serving Vancouver and the Lower Mainland."
>
  <!-- Hero Section -->
  <section class="relative bg-[#1e3a5f] py-24 md:py-32">
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <defs>
          <pattern id="about-grid" width="10" height="10" patternUnits="userSpaceOnUse">
            <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100" height="100" fill="url(#about-grid)" />
      </svg>
    </div>
    
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">About ABC Electrical</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Your trusted electrical partner in Vancouver since 2012
      </p>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1e3a5f] mb-6">Our Story</h2>
          <div class="space-y-4 text-gray-600 text-lg leading-relaxed">
            <p>
              Founded in 2012 by master electrician Dave Chen, ABC Electrical started as a one-truck operation serving Vancouver's West Side. Today, we're a team of 8 licensed electricians serving the entire Lower Mainland — but we've never lost that small-business feel.
            </p>
            <p>
              We believe every job deserves the same attention, whether it's a simple outlet repair or a full commercial buildout. That's why our customers come back — and why they send their friends.
            </p>
          </div>
        </div>
        <div class="relative">
          <img 
            src="https://placehold.co/600x400/1e3a5f/f5a623?text=ABC+Electrical+Team" 
            alt="ABC Electrical team at work" 
            class="rounded-xl shadow-lg w-full"
            loading="lazy"
          />
          <div class="absolute -bottom-6 -left-6 bg-[#f5a623] rounded-lg p-6 shadow-lg hidden md:block">
            <p class="text-3xl font-bold text-[#1e3a5f]">12+</p>
            <p class="text-[#1e3a5f] font-semibold">Years of Service</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-[#1e3a5f] mb-4">Our Values</h2>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto">The principles that guide everything we do</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="card-hover bg-white rounded-xl p-8 border border-gray-100">
          <div class="flex items-start">
            <div class="w-12 h-12 bg-[#1e3a5f] rounded-lg flex items-center justify-center flex-shrink-0 mr-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#f5a623]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-[#1e3a5f] mb-2">Safety First — always</h3>
              <p class="text-gray-600">We never compromise on safety. Every job follows strict safety protocols to protect your family, your property, and our team.</p>
            </div>
          </div>
        </div>
        
        <div class="card-hover bg-white rounded-xl p-8 border border-gray-100">
          <div class="flex items-start">
            <div class="w-12 h-12 bg-[#1e3a5f] rounded-lg flex items-center justify-center flex-shrink-0 mr-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#f5a623]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-[#1e3a5f] mb-2">Do It Right The First Time</h3>
              <p class="text-gray-600">Quality workmanship is our hallmark. We take pride in doing things properly so you don't have to call us back for the same issue.</p>
            </div>
          </div>
        </div>
        
        <div class="card-hover bg-white rounded-xl p-8 border border-gray-100">
          <div class="flex items-start">
            <div class="w-12 h-12 bg-[#1e3a5f] rounded-lg flex items-center justify-center flex-shrink-0 mr-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#f5a623]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-[#1e3a5f] mb-2">Treat Every Home Like Our Own</h3>
              <p class="text-gray-600">We respect your space. That means wearing boot covers, cleaning up after ourselves, and treating your property with care.</p>
            </div>
          </div>
        </div>
        
        <div class="card-hover bg-white rounded-xl p-8 border border-gray-100">
          <div class="flex items-start">
            <div class="w-12 h-12 bg-[#1e3a5f] rounded-lg flex items-center justify-center flex-shrink-0 mr-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#f5a623]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-[#1e3a5f] mb-2">Honest, Upfront Communication</h3>
              <p class="text-gray-600">No hidden fees, no surprises. We explain what needs to be done and why, and we keep you informed every step of the way.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-[#1e3a5f] mb-4">Meet The Team</h2>
        <p class="text-gray-600 text-lg max-w-2xl mx-auto">The people behind the power</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Dave Chen -->
        <div class="text-center">
          <div class="w-32 h-32 mx-auto mb-4 rounded-full overflow-hidden bg-gray-200">
            <img 
              src="https://placehold.co/200x200/1e3a5f/f5a623?text=DC" 
              alt="Dave Chen - Founder & Master Electrician" 
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <h3 class="text-xl font-bold text-[#1e3a5f]">Dave Chen</h3>
          <p class="text-[#f5a623] font-semibold">Founder & Master Electrician</p>
        </div>
        
        <!-- Maria Santos -->
        <div class="text-center">
          <div class="w-32 h-32 mx-auto mb-4 rounded-full overflow-hidden bg-gray-200">
            <img 
              src="https://placehold.co/200x200/1e3a5f/f5a623?text=MS" 
              alt="Maria Santos - Operations Manager" 
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <h3 class="text-xl font-bold text-[#1e3a5f]">Maria Santos</h3>
          <p class="text-[#f5a623] font-semibold">Operations Manager</p>
        </div>
        
        <!-- Team Members -->
        <div class="text-center">
          <div class="w-32 h-32 mx-auto mb-4 rounded-full bg-[#f5a623] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-[#1e3a5f]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[#1e3a5f]">Our Electricians</h3>
          <p class="text-gray-600">Plus 6 licensed electricians who show up on time and get it done</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 bg-[#f5a623]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-[#1e3a5f] mb-6">Ready to Work With Us?</h2>
      <p class="text-[#1e3a5f] text-lg mb-8 max-w-2xl mx-auto">Experience the ABC Electrical difference. Professional, reliable, and always here when you need us.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:6045550199" class="bg-[#1e3a5f] text-white px-8 py-4 rounded-lg text-lg font-semibold shadow-lg hover:bg-[#152d4a] transition-all inline-flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (604) 555-0199
        </a>
        <a href="/contact" class="bg-white text-[#1e3a5f] px-8 py-4 rounded-lg text-lg font-semibold shadow-lg hover:bg-gray-100 transition-all inline-flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
          </svg>
          Request a Quote
        </a>
      </div>
    </div>
  </section>
</MainLayout>
